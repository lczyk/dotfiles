{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.config/agent-hooks/block-dangerous.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.config/agent-hooks/discourage-bare-tail.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.config/agent-hooks/enforce-log-suffix.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.config/agent-hooks/enforce-tmp-ai.sh\""
          }
        ]
      },
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.config/agent-hooks/enforce-tmp-ai.sh\" --paths-from-patch"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat \"$HOME/.config/agent-guidance/workflow.md\"",
            "statusMessage": "Loading shared agent instructions..."
          },
          {
            "type": "command",
            "command": "[ -f \"${XDG_CONFIG_HOME:-$HOME/.config}/agent-state/lofi-off\" ] || cat \"$HOME/.config/agent-styles/lofi.md\"",
            "statusMessage": "Loading lofi style..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f \"${XDG_CONFIG_HOME:-$HOME/.config}/agent-state/lofi-off\" ] || cat \"$HOME/.config/agent-styles/lofi-reminder.md\"",
            "statusMessage": "Loading lofi style reminder..."
          }
        ]
      }
    ]
  }
}
