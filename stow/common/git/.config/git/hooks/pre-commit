#!/usr/bin/env bash
# warn on non-ASCII characters in staged changes; block entirely for agents.
# always block nocommit-tagged lines (scratch files, temp debug code, etc.).

if [ "$CLAUDECODE" = "1" ]; then
    LABEL="rejected"
    FAIL=1
else
    LABEL="warning"
    FAIL=0
fi

function check_non_ascii() {
    local diff="$1"

    if [ -z "$diff" ]; then
        return 0
    fi

    local hits
    if command -v rg >/dev/null 2>&1; then
        hits=$(printf '%s\n' "$diff" | rg -n '^\+[^+].*[^\x00-\x7F]' --color=never)
    elif command -v grep >/dev/null 2>&1; then
        hits=$(printf '%s\n' "$diff" | grep -nP '^\+[^+].*[^\x00-\x7F]')
    else
        hits=$(printf '%s\n' "$diff" | awk '/^\+[^+]/ && /[^\x00-\x7F]/ { print NR": "$0 }')
    fi

    if [ -n "$hits" ]; then
        printf '%s: non-ASCII in staged changes:\n' "$LABEL" >&2
        printf '%s\n' "$hits" >&2
        if [ "$FAIL" = "0" ]; then
            printf '%s: unless there is a functional reason for non-ASCII, please remove these characters from your changes.\n' "$LABEL" >&2
        fi
        return "$FAIL"
    fi
}

function check_nocommit() {
    local diff="$1"

    if [ -z "$diff" ]; then
        return 0
    fi

    local hits
    if command -v rg >/dev/null 2>&1; then
        hits=$(printf '%s\n' "$diff" | rg -in '^\+.*nocommit' --color=never)
    elif command -v grep >/dev/null 2>&1; then
        hits=$(printf '%s\n' "$diff" | grep -Ein '^\+.*nocommit')
    else
        hits=$(printf '%s\n' "$diff" | awk 'tolower($0) ~ /^\+.*nocommit/ { print NR": "$0 }')
    fi

    if [ -n "$hits" ]; then
        printf 'rejected: nocommit marker in staged changes:\n' >&2
        printf '%s\n' "$hits" >&2
        printf 'rejected: remove or unstage nocommit-tagged lines before committing.\n' >&2
        return 1
    fi
}

function main() {
    local diff
    diff=$(git diff --cached)

    local rc=0
    check_non_ascii "$diff" || rc=$?
    check_nocommit "$diff" || rc=$?
    return $rc
}

main
