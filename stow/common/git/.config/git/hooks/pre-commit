#!/usr/bin/env bash
# staged-diff guard rails:
#   - non-ASCII / trailing whitespace: warn for humans, block for agents.
#   - secrets / nocommit markers: always block.
#
# every check runs over added content lines only -- see _added_lines.
#
# known blind spot: git renders UTF-16 and binary files as "Binary files
# differ", so their contents never reach any check. this hook is a speed bump,
# not a secrets manager.

if [ "$CLAUDECODE" = "1" ]; then
    LABEL="rejected"
    FAIL=1
else
    LABEL="warning"
    FAIL=0
fi

# PRECOMMIT_NO_RG=1 forces the grep/awk fallback path. the bats suite sets it
# to exercise the branch that runs on boxes w/out ripgrep -- that branch used
# to rely on `grep -P`, which BSD grep lacks, so it silently matched nothing.
_has_rg() {
    [ -z "$PRECOMMIT_NO_RG" ] && command -v rg >/dev/null 2>&1
}

_added_lines() {
    # added content lines only. the file header is `+++ b/path` -- note the
    # space. an added line whose content starts with `++` renders as
    # `+++counter;` with no space, so it must NOT be filtered out.
    # residual ambiguity: an added line whose content is literally `++ x`.
    printf '%s\n' "$1" | awk '/^\+/ && !/^\+\+\+ /'
}

function check_non_ascii() {
    local added="$1"

    # anything outside tab + printable ASCII (0x20-0x7E). the fallback spells
    # the class with literal bytes: BSD awk/grep do not honour `\x` escapes,
    # they treat them as the literal chars x, 0, 7, F -- which silently turns
    # `[^\x00-\x7F]` into a class that matches nearly every line.
    local hits
    if _has_rg; then
        hits=$(printf '%s\n' "$added" | rg --color=never -e '[^\t\x20-\x7E]')
    else
        hits=$(printf '%s\n' "$added" | LC_ALL=C grep -E -e $'[^\t -~]')
    fi

    if [ -n "$hits" ]; then
        printf '%s: non-ASCII in staged changes:\n' "$LABEL" >&2
        printf '%s\n' "$hits" >&2
        if [ "$FAIL" = "0" ]; then
            printf '%s: unless there is a functional reason for non-ASCII, please remove these characters from your changes.\n' "$LABEL" >&2
        else
            printf '%s: if you believe this commit should actually happen and there is a good reason for it (e.g. the file genuinely requires non-ASCII content -- test fixtures, locale data, i18n strings), explicitly ask the user for permission to use the --no-verify flag.\n' "$LABEL" >&2
        fi
        return "$FAIL"
    fi
}

function check_trailing_ws() {
    local added="$1"

    local hits pattern=$'[ \t]+$'
    if _has_rg; then
        hits=$(printf '%s\n' "$added" | rg --color=never -e "$pattern")
    else
        hits=$(printf '%s\n' "$added" | grep -E -e "$pattern")
    fi

    if [ -n "$hits" ]; then
        printf '%s: trailing whitespace in staged changes:\n' "$LABEL" >&2
        printf '%s\n' "$hits" >&2
        printf '%s: strip trailing spaces/tabs before committing.\n' "$LABEL" >&2
        if [ "$FAIL" = "1" ]; then
            printf '%s: if this is a false positive (e.g. the file requires trailing whitespace as significant content), explicitly ask the user for permission to use the --no-verify flag.\n' "$LABEL" >&2
        fi
        return "$FAIL"
    fi
}

function check_secrets() {
    local added="$1"

    # high-signal secret patterns. ERE only -- no PCRE, so the grep fallback
    # behaves identically to the rg path.
    #   AKIA...                      AWS access key id
    #   gh[posur]_...                GitHub PATs
    #   sk-...                       Anthropic (sk-ant-) / OpenAI (sk-, sk-proj-)
    #   xox[baprs]-...               Slack tokens
    #   -----BEGIN ... PRIVATE KEY   PEM block (incl. GCP service-account json)
    #   password= "literal"          quoted assignment, 8+ non-space chars
    #   ^PASSWORD=literal            unquoted env-file assignment, 8+ chars
    #
    # the unquoted branch is anchored to line start (after the diff `+`) so it
    # catches .env / shell / Makefile leaks w/out flagging `f(token=some_val)`.
    # deliberately not matched: bare JWTs -- too many false positives.
    local q="\"'"
    local pattern="(AKIA[0-9A-Z]{16}|gh[posur]_[A-Za-z0-9]{20,}|sk-[A-Za-z0-9_-]{20,}|xox[baprs]-[A-Za-z0-9-]{10,}|-----BEGIN ([A-Z]+ )?PRIVATE KEY-----|(password|passwd|api[_-]?key|secret|token)[[:space:]]*[:=][[:space:]]*[${q}][^${q} ]{8,}[${q}]|^\+[[:space:]]*(export[[:space:]]+)?(password|passwd|api[_-]?key|secret|token)=[^${q}[:space:]]{8,})"

    local hits
    if _has_rg; then
        hits=$(printf '%s\n' "$added" | rg -i --color=never -e "$pattern")
    else
        hits=$(printf '%s\n' "$added" | grep -iE -e "$pattern")
    fi

    if [ -n "$hits" ]; then
        printf 'rejected: possible secret in staged changes:\n' >&2
        printf '%s\n' "$hits" >&2
        printf 'rejected: remove the secret, rotate the credential, and add the file to .gitignore or use a secrets manager.\n' >&2
        printf 'rejected: if this is a false positive (test fixture, doc example), explicitly ask the user for permission to use --no-verify.\n' >&2
        return 1
    fi
}

function check_nocommit() {
    local added="$1"

    local hits
    if _has_rg; then
        hits=$(printf '%s\n' "$added" | rg -i --color=never -e 'nocommit')
    else
        hits=$(printf '%s\n' "$added" | grep -iE -e 'nocommit')
    fi

    if [ -n "$hits" ]; then
        printf 'rejected: nocommit marker in staged changes:\n' >&2
        printf '%s\n' "$hits" >&2
        printf 'rejected: remove or unstage nocommit-tagged lines before committing.\n' >&2
        printf 'rejected: if you believe this commit should actually happen and there is a good reason for it (e.g. the file documents or tests the nocommit marker itself, like this hook and its tests), explicitly ask the user for permission to use the --no-verify flag.\n' >&2
        return 1
    fi
}

function main() {
    local diff added
    # --no-ext-diff / --no-color / --no-textconv: a user's diff.external,
    # color.diff=always, or a textconv filter would otherwise reshape the
    # output and every pattern below would quietly stop matching.
    diff=$(git diff --cached --no-ext-diff --no-color --no-textconv)
    added=$(_added_lines "$diff")

    if [ -z "$added" ]; then
        return 0
    fi

    local rc=0
    check_non_ascii "$added" || rc=$?
    check_trailing_ws "$added" || rc=$?
    check_secrets "$added" || rc=$?
    check_nocommit "$added" || rc=$?
    return $rc
}

main
