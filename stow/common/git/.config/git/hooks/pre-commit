#!/usr/bin/env bash
# warn on non-ASCII characters in staged changes.

function main() {
    local diff
    diff=$(git diff --cached)

    if [ -z "$diff" ]; then
        return 0
    fi

    local hits
    if command -v rg >/dev/null 2>&1; then
        hits=$(printf '%s\n' "$diff" | rg -n '^\+[^+].*[^\x00-\x7F]' --color=never)
    elif command -v grep >/dev/null 2>&1; then
        hits=$(printf '%s\n' "$diff" | grep -nP '^\+[^+].*[^\x00-\x7F]')
    else
        hits=$(printf '%s\n' "$diff" | awk '/^\+[^+]/ && /[^\x00-\x7F]/ { print NR": "$0 }')
    fi

    if [ -n "$hits" ]; then
        printf 'warning: non-ASCII in staged changes:\n' >&2
        printf '%s\n' "$hits" >&2
        printf 'warning: unless there is a functional reason for non-ASCII, please remove these characters from your changes.\n' >&2
    fi
}

main
