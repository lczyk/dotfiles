#!/usr/bin/env bash

if [ "$CLAUDECODE" = "1" ]; then
    LABEL="rejected"
    FAIL=1
else
    LABEL="warning"
    FAIL=0
fi

function _fail() {
    printf '%s: %s\n' "$LABEL" "$1" >&2
    shift
    for line in "$@"; do
    printf '  %s\n' "$line" >&2
    done
    exit $FAIL
}

HEADERS=(feat fix docs test refactor chore bench revert ci perf release TODO FIXME)

function main() {
    local msg="$1"
    local subject
    subject=$(head -n1 "$msg")

    # -- co-author ban --------------------------------------------------
    if grep -qi "Co-Authored-By:" "$msg"; then
      _fail "commits must not be co-authored by agents"
    fi

    # -- conventional commits prefix ------------------------------------
    local types_alt types_list
    types_alt=$(IFS='|'; echo "${HEADERS[*]}")
    types_list=$(IFS=,; echo "${HEADERS[*]}" | sed 's/,/:, /g')":"
    if ! echo "$subject" | grep -qE "^(${types_alt})(\([a-z0-9._-]+\))?(!|\?)?: "; then
      _fail "subject must use Conventional Commits" \
           "  valid: ${types_list}" \
           "  optional scope: feat(scope):, fix(api):, docs(claude):" \
           "  suffix markers: !: (intentional breakage)  ?: (unverified)"
    fi

    # -- no ?! (outraged question) --------------------------------------
    if grep -Fq '?!' "$msg"; then
      _fail "avoid ?! in technical prose -- rephrase"
    fi

    # -- ASCII only -- full message -------------------------------------
    if ! iconv -f ASCII -t ASCII "$msg" >/dev/null 2>&1; then
      _fail "commit message must be ASCII only (no emoji, em-dash, smart quotes, ellipsis, arrows, etc.)"
    fi

    exit 0
}

main "$@"
