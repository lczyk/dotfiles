[user]
name = lczyk
email = marcin.konow@lczyk.xyz

[include]
path = ~/.config/git/config.local

[core]
hooksPath = ~/.config/git/hooks

[init]
defaultBranch = main

[difftool]
prompt = false

[difftool "diffpdf"]
# cmd = diff-pdf --view \"$LOCAL\" \"$REMOTE\"
cmd = echo \"$LOCAL\" && diff-pdf --skip-identical -v \"$LOCAL\" \"$REMOTE\" | tail -n1

[difftool "diffpdf-view"]
cmd = diff-pdf --view \"$LOCAL\" \"$REMOTE\"

# gpg signing
[commit]
gpgsign = true

[gpg]
program = gpg

# large file storage
[filter "lfs"]
clean = git-lfs clean -- %f
smudge = git-lfs smudge -- %f
process = git-lfs filter-process
required = true

# strip transient claude-code settings on commit (see .gitattributes in dotfiles repo)
# required: a missing/failing clean filter must hard-fail `git add`, not stage
# the raw file with the machine-local state still in it. required demands both
# directions, so the smudge side needs an explicit pass-through `cat`.
[filter "claudecfg"]
	clean = "jq -S 'del(.effortLevel, .model, .theme, .tui, .voiceEnabled)'"
	smudge = cat
	required = true

# strip Codex machine-local state while retaining stable config.toml settings
[filter "codexcfg"]
	clean = "bash \"$HOME/.config/git/filters/codexcfg-clean.sh\""
	smudge = cat
	required = true

# commit only explicitly approved copilot-cli settings
[filter "copilotcfg"]
	clean = "jq -S '{footer, includeCoAuthoredBy, theme} | with_entries(select(.value != null))'"
	smudge = cat
	required = true

# https://blog.gitbutler.com/how-git-core-devs-configure-git/

[column]
ui = auto

[branch]
sort = -committerdate

[tag]
sort = version:refname

[diff]
algorithm = histogram
colorMoved = plain
mnemonicPrefix = true
renames = true

[push]
default = simple
autoSetupRemote = true
followTags = true

[fetch]
prune = true
pruneTags = true
all = true

[help]
autocorrect = prompt

[rerere]
enabled = true
autoupdate = true

[rebase]
updateRefs = true
autoStash = true

[merge]
conflictstyle = zdiff3

[alias]
tree = log --graph --oneline --all --decorate
dc = diff --compact-summary

[help]
autoCorrect = never
